# SITVO — HTTPS con sitvo.net (ejemplo tras certbot o certificado manual)
# Copiar/adaptar a /etc/nginx/conf.d/sit.conf y: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name sitvo.net www.sitvo.net 77.37.74.122;
    return 301 https://sitvo.net$request_uri;
}

server {
    listen 443 ssl http2;
    server_name sitvo.net www.sitvo.net;

    # Certbot suele dejar estas rutas; ajustar si usas otro proveedor
    ssl_certificate     /etc/letsencrypt/live/sitvo.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sitvo.net/privkey.pem;

    client_max_body_size 100M;

    root /var/www/sit;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8081/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
