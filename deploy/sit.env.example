# Copiar a /etc/sit/sit.env en el VPS (chmod 600). No subir valores reales al repositorio.

SIT_JWT_SECRET=cambiar_por_cadena_aleatoria_minimo_32_caracteres
SIT_MONGODB_URI=mongodb://sit_app:CONTRASEÑA@127.0.0.1:27017/sit_titulacion?authSource=sit_titulacion
SIT_MAIL_PASSWORD=contraseña_outlook_dep_no_subir_aqui
SIT_CERT_BASE_URL=https://sitvo.net
SIT_SOFFICE_PATH=/usr/bin/soffice
SIT_ANEXO92_PLANTILLA=/opt/sit/templates/anexo-9-2.docx
SIT_KEYSTORE_PATH=/opt/sit/keystore/sit-keystore.p12
SIT_KEYSTORE_PASSWORD=otra_contraseña_fuerte
